# Environment Configuration Template
# Copy this file to .env and update with your values

# API Configuration
API_BASE_URL=http://localhost:8000/api
API_TIMEOUT=30

# Security
ENCRYPTION_KEY=your-encryption-key-here

# App Settings
DEBUG_MODE=True
APP_VERSION=1.0.0

# Cache Settings
CACHE_DIR=cache
MAX_CACHE_SIZE_MB=100

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log
