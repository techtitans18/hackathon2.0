<HospitalManagementScreen>:
    name: 'hospital_management'

    MDBoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            title: "Hospital Management"
            left_action_items: [["arrow-left", lambda x: setattr(root.manager, 'current', 'admin_dashboard')]]

        MDScrollView:
            MDList:
                id: hospitals_list

    MDFloatingActionButton:
        icon: "plus"
        pos_hint: {"right": 0.95, "y": 0.05}
        on_release: root.show_add_dialog()
