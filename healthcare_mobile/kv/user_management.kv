<UserManagementScreen>:
    name: 'user_management'
    
    MDBoxLayout:
        orientation: 'vertical'
        
        MDTopAppBar:
            title: "User Management"
            left_action_items: [["arrow-left", lambda x: setattr(root.manager, 'current', 'admin_dashboard')]]
        
        MDScrollView:
            MDList:
                id: users_list
